<section class="module module--hero{% if module.theme %} module--theme-{{ module.theme }}{% endif %}">
  <div class="container">
    <div class="hero__content">
      {% if module.pretitle %}
        <span class="hero__pretitle">{{ module.pretitle }}</span>
      {% endif %}
      <h1 class="hero__title">{{ module.title }}</h1>
      
      {% if module.description %}
        <p class="hero__description">{{ module.description }}</p>
      {% endif %}
      
      {% if module.cta %}
        <div class="hero__cta">
          <a href="{{ module.cta.url }}" class="btn{% if module.cta.style %} btn--{{ module.cta.style }}{% endif %}">
            {{ module.cta.text }}
          </a>
        </div>
      {% endif %}
    </div>
    
    {% if module.image %}
      <div class="hero__image">
        <img src="{{ module.image }}" alt="{{ module.imageAlt or module.title }}" loading="eager">
      </div>
    {% endif %}
  </div>
</section>
