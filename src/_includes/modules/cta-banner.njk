<section class="module module--cta-banner{% if module.theme %} module--theme-{{ module.theme }}{% endif %}">
  <div class="container">
    <div class="cta-banner__content">
      {% if module.pretitle %}
        <span class="cta-banner__pretitle">{{ module.pretitle }}</span>
      {% endif %}
      
      <h2 class="cta-banner__title">{{ module.title }}</h2>
      
      {% if module.description %}
        <p class="cta-banner__description">{{ module.description }}</p>
      {% endif %}
      
      {% if module.cta %}
        <div class="cta-banner__actions">
          <a href="{{ module.cta.url }}" class="btn{% if module.cta.style %} btn--{{ module.cta.style }}{% else %} btn--primary{% endif %}">
            {{ module.cta.text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>
