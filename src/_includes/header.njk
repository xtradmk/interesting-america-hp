<header class="site-header">
  <div class="container">
    <a href="/" class="logo" aria-label="{{ site.name }} - Back to Home">
      <span class="logo__text">{{ site.name }}</span>
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {%- for item in site.nav -%}
          <li class="nav-item{% if page.url == item.url %} nav-item--active{% endif %}">
            <a href="{{ item.url }}" class="nav-link">{{ item.text }}</a>
          </li>
        {%- endfor -%}
      </ul>
      <a class="nav-cta" href="/contact/">Start project</a>
    </nav>
  </div>
</header>